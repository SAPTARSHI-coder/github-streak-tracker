# GitHub Streak Tracker — Environment Variables
#
# HOW TO USE THIS FILE:
#   1. Copy this file:   cp .env.example .env
#   2. Fill in your values below
#   3. Never commit .env — it is already in .gitignore
#
# ─────────────────────────────────────────────────────────────────────────────

# REQUIRED ────────────────────────────────────────────────────────────────────

# Your GitHub Personal Access Token.
# How to create one:
#   → Go to https://github.com/settings/tokens
#   → Click "Generate new token (classic)"
#   → Give it a name like "streak-tracker"
#   → You do NOT need to check any scopes — public data needs zero permissions
#   → Copy the generated token and paste it below
GITHUB_TOKEN=your_github_personal_access_token_here

# OPTIONAL ────────────────────────────────────────────────────────────────────

# How long to cache each user's SVG in memory, in seconds.
# Default is 3600 (1 hour). Lower = fresher data, more GitHub API calls.
# Higher = fewer API calls, slightly stale data.
CACHE_TTL_SECONDS=3600

# The HTTP port the local dev server listens on.
# Change this if port 3000 is already in use on your machine.
PORT=3000
